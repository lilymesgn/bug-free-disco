# ============================================================
# Fit Tracker PRO — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# All VITE_* variables are bundled into the client build and
# are visible to anyone who downloads the app — do not put
# secret keys here.
# ============================================================


# ── Supabase (required — this is the app's database) ─────────────────────────
#
# 1. Create a project at https://supabase.com
# 2. Go to Project Settings → API and copy the Project URL + anon public key
# 3. Run supabase/migrations/0001_init.sql in the Supabase SQL Editor
#    to create all tables and Row Level Security policies
#
# The anon key is safe to expose client-side — RLS restricts every table
# so users can only ever read/write their own data.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key


# ── Stripe (required for real payments) ──────────────────────────────────────
#
# 1. Create a Product in your Stripe dashboard (Products → Add product)
# 2. Add two Prices: one monthly, one yearly
# 3. For each Price, create a Payment Link (Payment Links → New)
#    - Set success_url = https://yourapp.com/subscription?session=success
#    - Set cancel_url  = https://yourapp.com/subscription
# 4. Paste the Payment Link URLs below
#
# Without these, the app still runs — the Upgrade button shows a
# configuration message instead of crashing or showing a fake form.

VITE_STRIPE_PAYMENT_LINK_MONTHLY=https://buy.stripe.com/REPLACE_ME
VITE_STRIPE_PAYMENT_LINK_YEARLY=https://buy.stripe.com/REPLACE_ME_YEARLY


# ── App URL (optional) ────────────────────────────────────────────────────────
#
# Your deployed app's public URL. Used for Stripe redirect URLs.
# Defaults to window.location.origin at runtime if not set.
# Required if you deploy to a custom domain.

# VITE_APP_URL=https://fittrackerpro.app


# ── Notes on API keys ─────────────────────────────────────────────────────────
#
# Gemini API key and OpenAI API key are entered by users in the app
# (AI Coach tab → key icon) and stored in their browser's localStorage.
# They are NOT environment variables — each user uses their own key.
#
# Get a free Gemini API key at: https://aistudio.google.com/apikey
